<Window x:Class="PendriveRescue.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Pendrive Rescue"
        Height="820"
        MinHeight="720"
        Width="1220"
        MinWidth="1060"
        Background="#EDF2F6"
        FontFamily="Segoe UI">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility" />
        <SolidColorBrush x:Key="InkBrush" Color="#102033" />
        <SolidColorBrush x:Key="MutedBrush" Color="#657386" />
        <SolidColorBrush x:Key="PanelBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="BorderBrushSoft" Color="#D8E0E8" />
        <SolidColorBrush x:Key="AccentBrush" Color="#176B87" />
        <SolidColorBrush x:Key="AccentDarkBrush" Color="#0D4F63" />
        <SolidColorBrush x:Key="DangerBrush" Color="#9D2F2F" />
        <SolidColorBrush x:Key="DangerDarkBrush" Color="#7A2323" />

        <Style TargetType="ToolTip">
            <Setter Property="Background" Value="#172637" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="MaxWidth" Value="400" />
            <Setter Property="Padding" Value="12,9" />
            <Setter Property="Placement" Value="Mouse" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToolTip">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="#31465A"
                                BorderThickness="1"
                                CornerRadius="5"
                                Padding="{TemplateBinding Padding}">
                            <ContentControl Content="{TemplateBinding Content}"
                                            MaxWidth="376">
                                <ContentControl.ContentTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}"
                                                   TextWrapping="Wrap"
                                                   LineHeight="19"
                                                   TextOptions.TextFormattingMode="Display" />
                                    </DataTemplate>
                                </ContentControl.ContentTemplate>
                            </ContentControl>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource PanelBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="18" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
        </Style>

        <Style x:Key="SectionTitle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
            <Setter Property="FontSize" Value="17" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style x:Key="LabelText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource MutedBrush}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Margin" Value="0,0,0,3" />
        </Style>

        <Style x:Key="ValueText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>

        <Style x:Key="CommandButton" TargetType="Button">
            <Setter Property="MinHeight" Value="38" />
            <Setter Property="MinWidth" Value="108" />
            <Setter Property="Padding" Value="16,7" />
            <Setter Property="Margin" Value="0,0,10,10" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="ToolTipService.InitialShowDelay" Value="350" />
            <Setter Property="ToolTipService.ShowDuration" Value="15000" />
            <Setter Property="ToolTipService.ShowOnDisabled" Value="True" />
            <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
            <Setter Property="Background" Value="#F8FAFC" />
            <Setter Property="BorderBrush" Value="#CBD5DF" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#EEF4F7" />
                                <Setter Property="BorderBrush" Value="#AFC0CE" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.68" />
                                <Setter Property="Foreground" Value="#8895A5" />
                                <Setter Property="Background" Value="#F4F7FA" />
                                <Setter Property="Cursor" Value="Arrow" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButton" BasedOn="{StaticResource CommandButton}" TargetType="Button">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="{StaticResource AccentBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource AccentDarkBrush}" />
                                <Setter Property="BorderBrush" Value="{StaticResource AccentDarkBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.68" />
                                <Setter Property="Foreground" Value="#8895A5" />
                                <Setter Property="Background" Value="#E9EEF3" />
                                <Setter Property="BorderBrush" Value="#D4DDE5" />
                                <Setter Property="Cursor" Value="Arrow" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DangerButton" BasedOn="{StaticResource CommandButton}" TargetType="Button">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="{StaticResource DangerBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource DangerDarkBrush}" />
            <Setter Property="MinWidth" Value="128" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource DangerDarkBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.68" />
                                <Setter Property="Foreground" Value="#8895A5" />
                                <Setter Property="Background" Value="#E9EEF3" />
                                <Setter Property="BorderBrush" Value="#D4DDE5" />
                                <Setter Property="Cursor" Value="Arrow" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="MinHeight" Value="38" />
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="BorderBrush" Value="#CBD5DF" />
            <Setter Property="Background" Value="#FBFCFE" />
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="ToolTipService.InitialShowDelay" Value="350" />
            <Setter Property="ToolTipService.ShowDuration" Value="15000" />
            <Setter Property="ToolTipService.ShowOnDisabled" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border x:Name="CheckChrome"
                                    Width="17"
                                    Height="17"
                                    Background="White"
                                    BorderBrush="#AEBBC7"
                                    BorderThickness="1"
                                    CornerRadius="3"
                                    VerticalAlignment="Center">
                                <TextBlock x:Name="CheckGlyph"
                                           Text="&#xE73E;"
                                           FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                           FontSize="11"
                                           Foreground="White"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Visibility="Collapsed" />
                            </Border>
                            <ContentPresenter Grid.Column="1"
                                              Margin="8,0,0,0"
                                              VerticalAlignment="Center" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="CheckChrome" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="CheckChrome" Property="Background" Value="{StaticResource AccentBrush}" />
                                <Setter TargetName="CheckChrome" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                <Setter TargetName="CheckGlyph" Property="Visibility" Value="Visible" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.55" />
                                <Setter Property="Cursor" Value="Arrow" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="GridLinesVisibility" Value="Horizontal" />
            <Setter Property="HeadersVisibility" Value="Column" />
            <Setter Property="AutoGenerateColumns" Value="False" />
            <Setter Property="CanUserAddRows" Value="False" />
            <Setter Property="CanUserDeleteRows" Value="False" />
            <Setter Property="SelectionMode" Value="Extended" />
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="#D8E0E8" />
            <Setter Property="RowHeight" Value="34" />
            <Setter Property="ColumnHeaderHeight" Value="36" />
            <Setter Property="ScrollViewer.CanContentScroll" Value="True" />
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto" />
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Auto" />
            <Setter Property="EnableRowVirtualization" Value="True" />
            <Setter Property="EnableColumnVirtualization" Value="True" />
        </Style>

        <Style x:Key="WorkflowTabControl" TargetType="TabControl">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabControl">
                        <Grid KeyboardNavigation.TabNavigation="Local">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Border HorizontalAlignment="Left"
                                    Background="#F2F5F8"
                                    CornerRadius="7"
                                    Padding="4">
                                <TabPanel IsItemsHost="True"
                                          KeyboardNavigation.TabIndex="1"
                                          Panel.ZIndex="1" />
                            </Border>
                            <ContentPresenter x:Name="PART_SelectedContentHost"
                                              Grid.Row="1"
                                              ContentSource="SelectedContent"
                                              KeyboardNavigation.TabIndex="2" />
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TaskTabItem" TargetType="TabItem">
            <Setter Property="Foreground" Value="{StaticResource MutedBrush}" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="MinWidth" Value="126" />
            <Setter Property="Padding" Value="14,9" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="ToolTipService.InitialShowDelay" Value="300" />
            <Setter Property="ToolTipService.ShowDuration" Value="15000" />
            <Setter Property="ToolTipService.ShowOnDisabled" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="TabChrome"
                                Background="Transparent"
                                BorderBrush="Transparent"
                                BorderThickness="1"
                                CornerRadius="5"
                                Padding="{TemplateBinding Padding}">
                            <StackPanel Orientation="Horizontal"
                                        HorizontalAlignment="Center">
                                <TextBlock Text="{TemplateBinding Tag}"
                                           FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                           FontSize="15"
                                           Margin="0,0,8,0"
                                           VerticalAlignment="Center" />
                                <ContentPresenter ContentSource="Header"
                                                  RecognizesAccessKey="True"
                                                  VerticalAlignment="Center" />
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="TabChrome" Property="Background" Value="#E7EEF3" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Foreground" Value="{StaticResource AccentDarkBrush}" />
                                <Setter TargetName="TabChrome" Property="Background" Value="White" />
                                <Setter TargetName="TabChrome" Property="BorderBrush" Value="#CAD7E1" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ProfileRadio" TargetType="RadioButton">
            <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="ToolTipService.InitialShowDelay" Value="300" />
            <Setter Property="ToolTipService.ShowDuration" Value="15000" />
            <Setter Property="ToolTipService.ShowOnDisabled" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="ProfileChrome"
                                Background="#F8FAFC"
                                BorderBrush="#CAD5DF"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ProfileChrome" Property="Background" Value="#EEF4F7" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="ProfileChrome" Property="Background" Value="#E5F2F5" />
                                <Setter TargetName="ProfileChrome" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                <Setter Property="Foreground" Value="{StaticResource AccentDarkBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header actions remain outside the main workflow so they are always easy to find. -->
        <Grid Grid.Row="0" Margin="0,0,0,18">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Text="Pendrive Rescue"
                           FontSize="30"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource InkBrush}" />
                <TextBlock Text="Recover files first. Repair only after you understand the risk."
                           Foreground="{StaticResource MutedBrush}"
                           FontSize="14"
                           Margin="0,4,0,0" />
            </StackPanel>
            <StackPanel Grid.Column="1"
                        Orientation="Horizontal"
                        VerticalAlignment="Center">
                <Button Content="Refresh"
                        Style="{StaticResource CommandButton}"
                        Command="{Binding RefreshDevicesCommand}"
                        ToolTip="Refresh the USB list. Use this after connecting, removing, repairing, or formatting a drive so the app can find its latest drive letter and status." />
                <Button Content="Cancel"
                        Style="{StaticResource CommandButton}"
                        Command="{Binding CancelCommand}"
                        Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibility}}"
                        Margin="0,0,0,10"
                        ToolTip="Stop the operation shown in the status area. Some Windows repair steps may need a moment before they can stop safely." />
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320" />
                <ColumnDefinition Width="20" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource Card}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <StackPanel DockPanel.Dock="Top" Margin="0,0,0,14">
                        <TextBlock Text="Devices" Style="{StaticResource SectionTitle}" />
                        <TextBlock Text="Physical USB disks and mounted volumes"
                                   Foreground="{StaticResource MutedBrush}"
                                   FontSize="12"
                                   Margin="0,3,0,0" />
                    </StackPanel>

                    <Border Grid.Row="1"
                            Background="#F8FBFD"
                            BorderBrush="#D8E0E8"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="18"
                            VerticalAlignment="Top">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasDevices}" Value="False">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel>
                            <TextBlock Text="No removable drives detected"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource InkBrush}" />
                            <TextBlock Text="Connect a pendrive, then press Refresh. Run as Administrator if DiskPart can see it but the app cannot."
                                       TextWrapping="Wrap"
                                       Foreground="{StaticResource MutedBrush}"
                                       FontSize="12"
                                       Margin="0,6,0,0" />
                        </StackPanel>
                    </Border>

                    <ListBox Grid.Row="1"
                             ItemsSource="{Binding Devices}"
                             SelectedItem="{Binding SelectedDevice}"
                             BorderThickness="0"
                             Background="Transparent"
                             HorizontalContentAlignment="Stretch"
                             ToolTip="Select the USB drive you want to work with. Before using Erase and Repair, carefully check its name, size, and drive letter because that action permanently deletes the selected drive.">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="12"
                                        Margin="0,0,0,10"
                                        Background="#F9FBFD"
                                        BorderBrush="#D8E0E8"
                                        BorderThickness="1"
                                        CornerRadius="7">
                                    <StackPanel>
                                        <TextBlock Text="{Binding DisplayName}"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource InkBrush}"
                                                   TextWrapping="Wrap" />
                                        <Grid Margin="0,8,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="{Binding PhysicalPath}"
                                                       Foreground="{StaticResource MutedBrush}"
                                                       FontSize="12"
                                                       TextTrimming="CharacterEllipsis" />
                                            <Border Grid.Column="1"
                                                    Background="#E9F5F3"
                                                    CornerRadius="10"
                                                    Padding="8,2"
                                                    Margin="8,0,0,0">
                                                <TextBlock Text="{Binding Status}"
                                                           Foreground="#176054"
                                                           FontSize="11"
                                                           FontWeight="SemiBold" />
                                            </Border>
                                        </Grid>
                                        <TextBlock Text="{Binding TotalSizeDisplay, StringFormat=Size: {0}}"
                                                   Foreground="{StaticResource MutedBrush}"
                                                   FontSize="12"
                                                   Margin="0,6,0,0" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <ScrollViewer Grid.Column="2"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          PanningMode="VerticalOnly"
                          ToolTipService.InitialShowDelay="600">
            <Grid Margin="0,0,10,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="360" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Style="{StaticResource Card}" Margin="0,0,0,14">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.ColumnSpan="4"
                                   Text="Selected Device"
                                   Style="{StaticResource SectionTitle}"
                                   Margin="0,0,0,14" />

                        <Border Grid.Row="1"
                                Grid.ColumnSpan="4"
                                Grid.RowSpan="2"
                                Panel.ZIndex="10"
                                Background="#F8FBFD"
                                BorderBrush="#D8E0E8"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="16">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasSelectedDevice}" Value="False">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <TextBlock Text="Select a detected pendrive to see disk number, file system, physical path, and recovery options."
                                       TextWrapping="Wrap"
                                       Foreground="{StaticResource MutedBrush}" />
                        </Border>

                        <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,18,0">
                            <TextBlock Text="Name" Style="{StaticResource LabelText}" />
                            <TextBlock Text="{Binding SelectedDevice.DisplayName, TargetNullValue=-}"
                                       Style="{StaticResource ValueText}" />
                        </StackPanel>
                        <StackPanel Grid.Row="1" Grid.Column="1" Margin="0,0,18,0">
                            <TextBlock Text="Drive letter" Style="{StaticResource LabelText}" />
                            <TextBlock Text="{Binding SelectedDevice.DriveLetterDisplay, TargetNullValue=-}"
                                       Style="{StaticResource ValueText}" />
                        </StackPanel>
                        <StackPanel Grid.Row="1" Grid.Column="2" Margin="0,0,18,0">
                            <TextBlock Text="File system" Style="{StaticResource LabelText}" />
                            <TextBlock Text="{Binding SelectedDevice.FileSystem, TargetNullValue=-}"
                                       Style="{StaticResource ValueText}" />
                        </StackPanel>
                        <StackPanel Grid.Row="1" Grid.Column="3">
                            <TextBlock Text="Capacity" Style="{StaticResource LabelText}" />
                            <TextBlock Text="{Binding SelectedDevice.TotalSizeDisplay, TargetNullValue=-}"
                                       Style="{StaticResource ValueText}" />
                        </StackPanel>

                        <Grid Grid.Row="2" Grid.ColumnSpan="4" Margin="0,16,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="130" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="160" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Disk number" Style="{StaticResource LabelText}" />
                                <TextBlock Text="{Binding SelectedDevice.DiskNumber, TargetNullValue=-}"
                                           Style="{StaticResource ValueText}" />
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Physical path" Style="{StaticResource LabelText}" />
                                <TextBlock Text="{Binding SelectedDevice.PhysicalPath, TargetNullValue=-}"
                                           Style="{StaticResource ValueText}" />
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Free space" Style="{StaticResource LabelText}" />
                                <TextBlock Text="{Binding SelectedDevice.FreeSizeDisplay, TargetNullValue=-}"
                                           Style="{StaticResource ValueText}" />
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Border>

                <Border Grid.Row="1" Style="{StaticResource Card}" Margin="0,0,0,14" Padding="16,12,16,14">
                    <TabControl Style="{StaticResource WorkflowTabControl}"
                                MinHeight="196">
                        <TabItem Header="Recovery"
                                 Tag="&#xE8B7;"
                                 Style="{StaticResource TaskTabItem}"
                                 ToolTip="Use Recovery when files are missing or the USB will not open normally. Start with Analyze, scan for files, then save recovered files to the computer or another drive.">
                            <Grid Margin="0,16,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="1.05*" />
                                    <ColumnDefinition Width="1" />
                                    <ColumnDefinition Width="1.15*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Margin="0,0,20,0">
                                    <TextBlock Text="Find and recover"
                                               Foreground="{StaticResource InkBrush}"
                                               FontWeight="SemiBold"
                                               FontSize="14" />
                                    <TextBlock Text="{Binding FoundCount, StringFormat={}{0} candidate files in the current results}"
                                               Foreground="{StaticResource MutedBrush}"
                                               FontSize="12"
                                               Margin="0,3,0,10" />
                                    <WrapPanel>
                                        <Button Content="Analyze"
                                                Style="{StaticResource CommandButton}"
                                                Command="{Binding AnalyzeProblemCommand}"
                                                ToolTip="Not sure what to do? Start here. Analyze checks the selected USB without erasing it and recommends the safest next recovery or repair step." />
                                        <Button Content="Quick Scan"
                                                Style="{StaticResource CommandButton}"
                                                Command="{Binding QuickScanCommand}"
                                                ToolTip="Look for files using Windows. Choose this faster scan when the USB has a drive letter, such as E:, and Windows can still read the drive." />
                                        <Button Content="Deep Scan"
                                                Style="{StaticResource PrimaryButton}"
                                                Command="{Binding DeepScanCommand}"
                                                ToolTip="Search the whole physical USB for recognizable file contents. This takes longer, but can help when Quick Scan misses files, Windows reports RAW, or no drive letter appears." />
                                        <Button Content="Recover Files..."
                                                Style="{StaticResource PrimaryButton}"
                                                Command="{Binding RecoverFilesCommand}"
                                                ToolTip="Choose where recovered files will be saved, then recover the selected scan results. Always save them to the computer or a different drive, not the damaged USB." />
                                    </WrapPanel>
                                </StackPanel>
                                <Border Grid.Column="1" Background="{StaticResource BorderBrushSoft}" />
                                <Grid Grid.Column="2" Margin="20,0,0,0">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <TextBlock Text="Recovery destination"
                                               Foreground="{StaticResource InkBrush}"
                                               FontWeight="SemiBold"
                                               FontSize="14" />
                                    <Grid Grid.Row="1" Margin="0,10,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBox Text="{Binding DestinationPath, UpdateSourceTrigger=PropertyChanged}"
                                                 ToolTip="This is the folder where recovered files will be saved. Use the computer or another physical drive; saving back to the damaged USB could overwrite files that are still recoverable." />
                                        <Button Grid.Column="1"
                                                Content="Browse"
                                                Style="{StaticResource CommandButton}"
                                                Command="{Binding BrowseDestinationCommand}"
                                                Margin="10,0,0,0"
                                                ToolTip="Open a folder chooser and select a safe place for recovered files on the computer or another drive." />
                                    </Grid>
                                    <Button Grid.Row="2"
                                            Content="Recover selected"
                                            Style="{StaticResource PrimaryButton}"
                                            Command="{Binding RecoverSelectedCommand}"
                                            HorizontalAlignment="Left"
                                            Margin="0,10,0,0"
                                            ToolTip="Copy every checked scan result to the destination folder shown above. Existing files are not intentionally changed on the source USB." />
                                </Grid>
                            </Grid>
                        </TabItem>

                        <TabItem Header="Repair"
                                 Tag="&#xE90F;"
                                 Style="{StaticResource TaskTabItem}"
                                 ToolTip="Use Repair when files are hidden, suspicious shortcut or script files appear, or Windows cannot use the USB correctly. Normalize and Safe Repair try to keep your files. Erase and Repair deletes everything.">
                            <Grid Margin="0,16,0,0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="0.9*" />
                                    <ColumnDefinition Width="1" />
                                    <ColumnDefinition Width="1.25*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Margin="0,0,20,0">
                                    <TextBlock Text="Maintenance"
                                               Foreground="{StaticResource InkBrush}"
                                               FontWeight="SemiBold"
                                               FontSize="14" />
                                    <WrapPanel Margin="0,10,0,0">
                                        <Button Content="Normalize USB"
                                                Style="{StaticResource PrimaryButton}"
                                                Command="{Binding CleanUsbMalwareArtifactsCommand}"
                                                ToolTip="Use this when personal files became hidden or suspicious shortcuts, scripts, or autorun files appeared. Normalize restores common hidden-file settings and quarantines known USB malware artifacts without formatting the drive. It cannot guarantee that an infected computer will not infect the USB again." />
                                        <Button Content="Safe Repair"
                                                Style="{StaticResource CommandButton}"
                                                Command="{Binding TrySafeRepairCommand}"
                                                ToolTip="Use this when the USB is read-only, has no drive letter, or reports file-system errors. Safe Repair asks Windows to remount the drive, clear common read-only flags, and run CHKDSK without formatting it. Back up important files first whenever possible." />
                                        <Button Content="Erase and Repair"
                                                Style="{StaticResource DangerButton}"
                                                Command="{Binding RepairFlashDriveCommand}"
                                                ToolTip="Warning: this permanently deletes every file and partition on the selected physical USB. Use it only after recovery or backup is complete. The drive is then rebuilt with the format profile selected on the right." />
                                    </WrapPanel>
                                </StackPanel>
                                <Border Grid.Column="1" Background="{StaticResource BorderBrushSoft}" />
                                <StackPanel Grid.Column="2" Margin="20,0,0,0">
                                    <TextBlock Text="Erase format profile"
                                               Foreground="{StaticResource InkBrush}"
                                               FontWeight="SemiBold"
                                               FontSize="14" />
                                    <WrapPanel Margin="0,9,0,0">
                                        <RadioButton Content="Full capacity (exFAT)"
                                                     GroupName="RepairProfile"
                                                     Style="{StaticResource ProfileRadio}"
                                                     IsChecked="{Binding UseModernFullCapacityFormat}"
                                                     ToolTip="Best for Windows computers and newer equipment. exFAT uses the full USB capacity and supports files larger than 4 GB, but some older printers, televisions, and car systems may not recognize it." />
                                        <RadioButton Content="Printers / devices (FAT32)"
                                                     GroupName="RepairProfile"
                                                     Style="{StaticResource ProfileRadio}"
                                                     IsChecked="{Binding UsePrinterCompatibilityFormat}"
                                                     ToolTip="Choose this for the widest compatibility with printers, televisions, car stereos, and older devices. FAT32 cannot store one file larger than 4 GB. On large USB drives, this profile creates a 30 GB partition for better device compatibility." />
                                    </WrapPanel>
                                    <TextBlock Text="{Binding RepairFormatSummary}"
                                               Foreground="{StaticResource MutedBrush}"
                                               FontSize="11"
                                               TextWrapping="Wrap"
                                               Margin="0,4,0,0" />
                                </StackPanel>
                                <StackPanel Grid.Row="1"
                                            Grid.ColumnSpan="3"
                                            Orientation="Horizontal"
                                            Margin="0,14,0,0">
                                    <CheckBox Content="Scan with Microsoft Defender"
                                              IsChecked="{Binding ScanWithDefenderDuringNormalize}"
                                              Foreground="{StaticResource InkBrush}"
                                              VerticalAlignment="Center"
                                              Margin="0,0,24,0"
                                              ToolTip="Recommended. Microsoft Defender first checks common infection locations on this computer, then scans the USB before and after Normalize. This requires Microsoft Defender to be available." />
                                    <CheckBox Content="Enable AutoRun blocker after Normalize"
                                              IsChecked="{Binding ProtectAfterNormalize}"
                                              Foreground="{StaticResource InkBrush}"
                                              VerticalAlignment="Center"
                                              ToolTip="Recommended for older Windows threats. After Normalize, the app creates a managed autorun.inf blocker that prevents one common automatic-start method. It is an extra layer, not a complete antivirus, and an infected computer can still write other malicious files." />
                                </StackPanel>
                            </Grid>
                        </TabItem>

                        <TabItem Header="Protection"
                                 Tag="&#xEA18;"
                                 Style="{StaticResource TaskTabItem}"
                                 ToolTip="Use Protection to ask Microsoft Defender to scan the selected USB or this computer. You can also add or remove the basic AutoRun blocker. These tools reduce risk but cannot make a USB completely immune to infection.">
                            <Grid Margin="0,16,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="1" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Margin="0,0,20,0">
                                    <TextBlock Text="Microsoft Defender"
                                               Foreground="{StaticResource InkBrush}"
                                               FontWeight="SemiBold"
                                               FontSize="14" />
                                    <TextBlock Text="{Binding DefenderStatus}"
                                               Foreground="{StaticResource MutedBrush}"
                                               Margin="0,4,0,0"
                                               TextWrapping="Wrap" />
                                    <WrapPanel Margin="0,11,0,0">
                                        <Button Content="Scan USB"
                                                Style="{StaticResource PrimaryButton}"
                                                Command="{Binding ScanUsbForMalwareCommand}"
                                                ToolTip="Ask Microsoft Defender to scan the selected USB and handle threats it recognizes. Keep the USB connected until the scan finishes, then review the status message." />
                                        <Button Content="Scan this PC"
                                                Style="{StaticResource CommandButton}"
                                                Command="{Binding ScanComputerForMalwareCommand}"
                                                ToolTip="Run a Microsoft Defender Quick Scan on this computer. This checks common places where active malware hides and is useful before cleaning a USB that may have been repeatedly reinfected." />
                                    </WrapPanel>
                                </StackPanel>
                                <Border Grid.Column="1" Background="{StaticResource BorderBrushSoft}" />
                                <StackPanel Grid.Column="2" Margin="20,0,0,0">
                                    <TextBlock Text="AutoRun blocker"
                                               Foreground="{StaticResource InkBrush}"
                                               FontWeight="SemiBold"
                                               FontSize="14"
                                               ToolTip="The blocker prevents one older Windows technique that tries to start a program automatically from the USB. It cannot stop malware that is already running on a computer from changing the drive." />
                                    <TextBlock Text="{Binding UsbProtectionStatus}"
                                               Foreground="{StaticResource MutedBrush}"
                                               Margin="0,4,0,0"
                                               TextWrapping="Wrap" />
                                    <WrapPanel Margin="0,11,0,0">
                                        <Button Content="Enable blocker"
                                                Style="{StaticResource PrimaryButton}"
                                                Command="{Binding EnableUsbProtectionCommand}"
                                                ToolTip="Create the managed autorun.inf blocker on the selected USB. This does not erase personal files and can be removed later from this tab." />
                                        <Button Content="Remove blocker"
                                                Style="{StaticResource CommandButton}"
                                                Command="{Binding DisableUsbProtectionCommand}"
                                                ToolTip="Remove only the AutoRun blocker created by Pendrive Rescue. Your personal files and unrelated autorun.inf content are not intentionally removed." />
                                    </WrapPanel>
                                </StackPanel>
                            </Grid>
                        </TabItem>
                    </TabControl>
                </Border>

                <Border Grid.Row="2" Style="{StaticResource Card}" MinHeight="300">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <Grid DockPanel.Dock="Top" Margin="0,0,0,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Scan Results" Style="{StaticResource SectionTitle}" />
                                <TextBlock Text="{Binding FoundCount, StringFormat={}  {0} file(s)}"
                                           Foreground="{StaticResource MutedBrush}"
                                           Margin="10,4,0,0" />
                            </StackPanel>
                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <TextBlock Text="{Binding SelectedFileCount, StringFormat={}{0} selected}"
                                           Foreground="{StaticResource MutedBrush}"
                                           VerticalAlignment="Center"
                                           Margin="0,0,12,0" />
                                <Menu Background="Transparent"
                                      VerticalAlignment="Center">
                                    <MenuItem Header="Results">
                                        <MenuItem.ToolTip>
                                            <ToolTip Content="Open commands for the current Scan Results list. You can select every result, clear the selection, or save a report for later review." />
                                        </MenuItem.ToolTip>
                                        <MenuItem Header="Select all"
                                                  Command="{Binding SelectAllFilesCommand}"
                                                  ToolTip="Check every file currently shown in Scan Results so they can all be recovered." />
                                        <MenuItem Header="Clear selection"
                                                  Command="{Binding ClearFileSelectionCommand}"
                                                  ToolTip="Uncheck every file currently shown in Scan Results. This does not delete any files." />
                                        <Separator />
                                        <MenuItem Header="Export report"
                                                  Command="{Binding ExportReportCommand}"
                                                  ToolTip="Save the latest scan or recovery details as a JSON report. This is useful for troubleshooting or keeping a record; it does not recover the files themselves." />
                                    </MenuItem>
                                </Menu>
                            </StackPanel>
                        </Grid>

                        <Grid Grid.Row="1">
                            <Border Background="#F8FBFD"
                                    BorderBrush="#D8E0E8"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Padding="18"
                                    VerticalAlignment="Top">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding HasFiles}" Value="False">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <StackPanel>
                                    <TextBlock Text="No scan results yet"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource InkBrush}" />
                                    <TextBlock Text="Run Analyze Problem first if the drive looks unhealthy, then use Quick Scan for mounted drives or Deep Scan for RAW/no-letter devices."
                                               TextWrapping="Wrap"
                                               Foreground="{StaticResource MutedBrush}"
                                               FontSize="12"
                                               Margin="0,6,0,0" />
                                </StackPanel>
                            </Border>

                            <DataGrid ItemsSource="{Binding Files}"
                                      IsReadOnly="False"
                                      MinHeight="220"
                                      VerticalAlignment="Stretch"
                                      VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Auto">
                                <DataGrid.Style>
                                    <Style BasedOn="{StaticResource {x:Type DataGrid}}" TargetType="DataGrid">
                                        <Setter Property="Visibility" Value="Visible" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding HasFiles}" Value="False">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </DataGrid.Style>
                            <DataGrid.Columns>
                                <DataGridCheckBoxColumn Header=""
                                                        Binding="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}"
                                                        Width="46" />
                                <DataGridTextColumn Header="Name"
                                                    Binding="{Binding FileName}"
                                                    IsReadOnly="True"
                                                    Width="2*" />
                                <DataGridTextColumn Header="Type"
                                                    Binding="{Binding Extension}"
                                                    IsReadOnly="True"
                                                    Width="90" />
                                <DataGridTextColumn Header="Size"
                                                    Binding="{Binding SizeDisplay}"
                                                    IsReadOnly="True"
                                                    Width="110" />
                                <DataGridTextColumn Header="Confidence"
                                                    Binding="{Binding Confidence}"
                                                    IsReadOnly="True"
                                                    Width="125" />
                                <DataGridTextColumn Header="Offset"
                                                    Binding="{Binding StartOffset}"
                                                    IsReadOnly="True"
                                                    Width="125" />
                                <DataGridTextColumn Header="State"
                                                    Binding="{Binding State}"
                                                    IsReadOnly="True"
                                                    Width="120" />
                            </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>
            </ScrollViewer>
        </Grid>

        <Border Grid.Row="2"
                Style="{StaticResource Card}"
                Padding="16"
                Margin="0,16,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="260" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="{Binding OperationTitle}"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource InkBrush}" />
                    <TextBlock Text="{Binding StatusMessage}"
                               Foreground="{StaticResource MutedBrush}"
                               TextWrapping="Wrap"
                               Margin="0,4,0,0" />
                </StackPanel>
                <ProgressBar Grid.Column="1"
                             Height="16"
                             Minimum="0"
                             Maximum="100"
                             Value="{Binding Progress}"
                             VerticalAlignment="Center"
                             Foreground="{StaticResource AccentBrush}" />
            </Grid>
        </Border>
    </Grid>
</Window>
